#!/usr/bin/env bash
# Shim that execs the plugin's venv Python with .papyrus.env sourced.
# All Python scripts and hooks invoke this instead of system python3 so the
# plugin has its own dependency set regardless of the user's shell environment.
set -e
HERE="$(cd "$(dirname "$0")/.." && pwd)"
if [ -f "$HERE/.papyrus.env" ]; then
  set -a
  # shellcheck disable=SC1091
  source "$HERE/.papyrus.env"
  set +a
fi
if [ ! -x "$HERE/.venv/bin/python" ]; then
  echo "papyrus-python: .venv not found. Run ./setup.sh first." >&2
  exit 1
fi
# macOS dyld doesn't search Homebrew lib dirs by default, so cairosvg fails
# to find libcairo. Add Homebrew's lib dir to the fallback path so cairocffi
# can dlopen it. Apple Silicon: /opt/homebrew, Intel: /usr/local.
if [ "$(uname -s)" = "Darwin" ] && command -v brew >/dev/null 2>&1; then
  brew_prefix="$(brew --prefix 2>/dev/null || true)"
  if [ -n "$brew_prefix" ] && [ -d "$brew_prefix/lib" ]; then
    export DYLD_FALLBACK_LIBRARY_PATH="$brew_prefix/lib${DYLD_FALLBACK_LIBRARY_PATH:+:$DYLD_FALLBACK_LIBRARY_PATH}"
  fi
fi
exec "$HERE/.venv/bin/python" "$@"
